PortSystem          1.0
PortGroup           github 1.0
PortGroup           cargo 1.0

# OpenVAF-Reloaded develops on a single "mob" branch. The first tag (v24.0.0mob)
# had 2022-era codegen that segfaults emitting OSDI metadata on LLVM 18; the
# v24.0.1mob tag (2026-06-29) is the first that builds and runs cleanly for us
# (it also adds Verilog-A arrays / laplace_nd / events / absdelay). We pin that
# tag. github.tarball_from archive + tag prefix "v" -> tag v24.0.1mob.
github.setup        OpenVAF OpenVAF-Reloaded 24.0.1mob v
github.tarball_from archive
name                openvaf
version             24.0.1mob
revision            0

# The github archive of tag v24.0.1mob extracts to OpenVAF-Reloaded-24.0.1mob
# (GitHub drops the leading "v"); pin distname/worksrcdir so the checksum key
# and the extracted dir line up.
distname            OpenVAF-Reloaded-24.0.1mob
worksrcdir          ${distname}

categories          cad science
license             GPL-3
maintainers         {icanalytica.com:degnan @bpdegnan} openmaintainer

description         Verilog-A to OSDI compact-model compiler (community fork)
long_description    OpenVAF is a Verilog-A compiler that compiles compact \
                    semiconductor device models into shared libraries exposing \
                    the OSDI interface, loadable by SPICE simulators such as \
                    ngspice and Xyce. This is OpenVAF-Reloaded, the actively \
                    maintained community fork (started by Arpad Burmen) of the \
                    original, now-unmaintained OpenVAF by Pascal Kuthe.

homepage            https://github.com/OpenVAF/OpenVAF-Reloaded

checksums           ${distname}${extract.suffix} \
                        rmd160  3ccbc3d78e8d30e92341d9c85997ac46fa6f990d \
                        sha256  5e3197b5e9118c9fa28c2ef0102377542f765d3e0791d1273c125a1dabd46b4b \
                        size    2291458

# --- LLVM backend -----------------------------------------------------------
# The fork selects the LLVM major via a cargo feature and supports 18-22. We use
# MacPorts llvm-18 (llvm-sys 181) and point llvm-sys at its private prefix.
depends_build-append    port:llvm-18
depends_lib-append      port:llvm-18

build.env-append        LLVM_SYS_181_PREFIX=${prefix}/libexec/llvm-18

# The openvaf/target crate's build.rs invokes the bare `llvm-lib`. MacPorts
# installs it as ${prefix}/libexec/llvm-18/bin/llvm-lib (only an -mp-18 copy is
# in ${prefix}/bin), so prepend that dir to PATH for the build.
build.env-append        PATH=${prefix}/libexec/llvm-18/bin:${prefix}/bin:${prefix}/sbin:/usr/bin:/bin:/usr/sbin:/sbin

# Harmless if LLVM ends up statically linked (see force-static below); kept as a
# safety net so a dynamic libLLVM (@rpath/libLLVM.dylib) would still resolve.
rust.flags-append       -Clink-arg=-Wl,-rpath,${prefix}/libexec/llvm-18/lib

# Build the CLI driver (binary "openvaf-r") with the LLVM 18 feature.
build.args-append       --features llvm18 -p openvaf-driver


set salsa_rev       73532d7d4d8b5b27f2c9f189a76e012d1fc4de09
# salsa: a patched, unpublished salsa fork (account pascalkuthe) pulled from git
# rather than crates.io. One github entry covers both member crates (salsa and
# salsa-macros from the same repo).
cargo.crates_github \
    salsa pascalkuthe/salsa master \
        ${salsa_rev} \
        840247281a08c4b132d794afaeabf71ae507c81ab1b20f2001d9cbffb983a0ee

# Post-extract fixups (this block runs after the cargo PortGroup's post-extract,
# which writes config.toml and the offline crate dirs):
#  1. salsa is a multi-crate git workspace; Cargo.lock needs salsa AND
#     salsa-macros (under components/) from the git source, but the PortGroup
#     only extracts the repo root. A cargo directory source resolves each
#     package by a top-level dir, so expose salsa-macros standalone (null
#     checksum manifest); it has only crates.io deps so it stands alone.
#  2. Drop the PortGroup's `branch = "master"` line: upstream patches salsa with
#     a bare `git = '...'` (default-branch SourceId); the branch line mismatches
#     so cargo would try to fetch under --frozen.
#  3. Force STATIC LLVM linking: mir_llvm requests the llvm-sys "prefer-dynamic"
#     feature; flip it to "force-static" (llvm-sys's own default) so the link
#     uses MacPorts llvm-18's static component libs. Feature-only edit, so
#     Cargo.lock stays valid under --frozen.
post-extract {
    set md          ${cargo.home}/macports
    set salsadir    ${md}/salsa-${salsa_rev}
    set macrosdir   ${md}/salsa-macros-${salsa_rev}
    if {![file exists ${macrosdir}] && \
         [file isdirectory ${salsadir}/components/salsa-macros]} {
        copy ${salsadir}/components/salsa-macros ${macrosdir}
        set fp [open ${macrosdir}/.cargo-checksum.json w]
        puts $fp {{"package":null,"files":{}}}
        close $fp
    }
    reinplace "/^branch = /d" ${cargo.home}/config.toml
    reinplace {s/prefer-dynamic/force-static/g} \
        ${worksrcpath}/openvaf/mir_llvm/Cargo.toml
}

destroot {
    # cargo sets CARGO_BUILD_TARGET (=the arch triple), so binaries land in
    # target/<triple>/release, not target/release.
    xinstall -m 0755 \
        ${worksrcpath}/target/[option triplet.${muniversal.build_arch}]/release/openvaf-r \
        ${destroot}${prefix}/bin/openvaf-r
}

